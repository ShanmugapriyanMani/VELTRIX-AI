# ═══════════════════════════════════════════════════════════════
# VELTRIX TRADING BOT — Environment Configuration
#
# Setup:
#   1. Copy this to .env: cp .env.example .env
#   2. Fill in your credentials in .env
#   3. Set TRADING_STAGE=BASIC or PLUS
#   4. Stage-specific settings live in .env.basic / .env.plus
# ═══════════════════════════════════════════════════════════════

# ── Upstox API Credentials ──
UPSTOX_LIVE_API_KEY=your-live-api-key
UPSTOX_LIVE_API_SECRET=your-live-secret
UPSTOX_LIVE_REDIRECT_URI=http://127.0.0.1:5000/callback
# UPSTOX_ACCESS_TOKEN=             # Optional: pre-set access token
# UPSTOX_TOTP_SECRET=              # Optional: TOTP for auto-login

# ── Telegram Notifications ──
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Stage: BASIC (₹50K) or PLUS (₹1.5L+) ──
# All trading settings are in .env.basic / .env.plus
TRADING_STAGE=BASIC
