# ═══════════════════════════════════════════════════════════════
# TRADING MODE — ALWAYS defaults to SANDBOX for safety
# ═══════════════════════════════════════════════════════════════
TRADING_MODE=SANDBOX

# ═══════════════════════════════════════════════════════════════
# UPSTOX API v3 CREDENTIALS — LIVE
# ═══════════════════════════════════════════════════════════════
UPSTOX_LIVE_API_KEY=your-live-api-key
UPSTOX_LIVE_API_SECRET=your-live-secret
UPSTOX_LIVE_REDIRECT_URI=http://127.0.0.1:5000/callback

# ═══════════════════════════════════════════════════════════════
# UPSTOX API v3 CREDENTIALS — SANDBOX
# ═══════════════════════════════════════════════════════════════
UPSTOX_SANDBOX_API_KEY=your-sandbox-api-key
UPSTOX_SANDBOX_API_SECRET=your-sandbox-secret
UPSTOX_SANDBOX_REDIRECT_URI=http://127.0.0.1:8000/callback

# ═══════════════════════════════════════════════════════════════
# TELEGRAM NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
